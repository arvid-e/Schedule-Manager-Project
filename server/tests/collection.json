  "item": [
    {
      "name": "register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomUser = \"user\" + pm.variables.replaceIn('{{$randomInt}}') + \"_user\";",
              "const randomPass = \"Password123\" + pm.variables.replaceIn('{{$randomInt}}') + \"!\";",
              "",
              "pm.environment.set(\"test_username\", randomUser);",
              "pm.environment.set(\"test_password\", randomPass);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "let responseJson;",
              "pm.test(\"Response body is valid JSON\", function () {",
              "    responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"response.status equals 'success'\", function () {",
              "    pm.expect(responseJson.status).to.eql(\"success\");",
              "});",
              "",
              "pm.test(\"response.message is a string\", function () {",
              "    pm.expect(responseJson.message).to.be.a(\"string\");",
              "});",
              "",
              "pm.test(\"response.data exists and is an object\", function () {",
              "    pm.expect(responseJson).to.exist;",
              "    pm.expect(responseJson).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"response.tokens exists and is strings\", function () { ",
              "    pm.expect(responseJson.tokens).to.exist;",
              "    pm.expect(responseJson.tokens.accessToken).to.be.a(\"string\");",
              "    pm.expect(responseJson.tokens.refreshToken).to.be.a(\"string\");",
              "});",
              "",
              "pm.environment.set(\"test_user\", responseJson._id);",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "{{test_username}}",
              "type": "text",
              "uuid": "e476d254-c7ca-40db-8f7c-602725662398"
            },
            {
              "key": "password",
              "value": "{{test_password}}",
              "type": "text",
              "uuid": "a46a2f69-4f0c-4537-b7f0-fb549cf6a899"
            }
          ]
        },
        "url": {
          "raw": "{{api_url}}/auth/register",
          "host": [
            "{{api_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },

              "});",
              "",
              "pm.test(\"response.data exists and is an object\", function () {",
              "    pm.expect(responseJson.data).to.exist;",
              "    pm.expect(responseJson.data).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"response.data.events is an array\", function () {",
              "    pm.expect(responseJson.data.events).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Warning: endpoint naming may differ from payload naming\", function () {",
              "    const endpointMentionsTasks = pm.request.url.toString().includes(\"/tasks\");",
              "    const payloadUsesEvents = responseJson && responseJson.data && Object.prototype.hasOwnProperty.call(responseJson.data, \"events\");",
              "",
              "    if (endpointMentionsTasks && payloadUsesEvents) {",
              "        console.warn(\"Naming note: the request endpoint uses '/tasks' while the response payload uses 'events'. This may be intentional, but is worth reviewing for consistency.\");",
              "    }",
              "",
              "    pm.expect(true).to.be.true;",
              "});"
            ],
